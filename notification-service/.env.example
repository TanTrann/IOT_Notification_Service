PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/iot_notifications

# JWT (auth middleware + đăng nhập /api/v1/auth/login)
JWT_SECRET=your_jwt_secret_here
# Thời hạn token cấp khi đăng nhập (mặc định 30d)
JWT_EXPIRES=30d

# Firebase credentials
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# MQTT — nghe ké broker chung của hệ IoT (HiveMQ Cloud). Bật TLS vì port 8883 -> dùng mqtts://
MQTT_BROKER_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_CLIENT_ID=iot-notification-service
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password

# Topic thông báo — song song với planttree/{deviceId}/sensors|commands của Phong.
# Nghe mọi thiết bị bằng wildcard; deviceId được bóc từ topic. Phong publish JSON lên đây.
MQTT_NOTIFICATION_TOPIC=planttree/+/notifications

# deviceId mặc định cho script test (scripts/publish-test.js) khi không truyền tham số.
DEFAULT_DEVICE_ID=ESP32S3_Zone1

# API key cho /internal/* (client đăng ký/hủy FCM token qua /internal/push/token).
# Đặt chuỗi ngẫu nhiên đủ dài, gửi cho bên tích hợp qua kênh riêng.
INTERNAL_API_KEY=change_me_to_a_random_secret

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
