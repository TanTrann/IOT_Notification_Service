PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/iot_notifications

# Firebase credentials
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Nhận thông báo từ Phong qua HTTP: Phong POST /internal/notify (kèm header x-api-key).
# Không còn nghe MQTT — service chỉ nhận tin Phong đã xử lý rồi đẩy FCM lên màn hình.

# deviceId mặc định cho script test (scripts/publish-test.js) khi không truyền tham số.
DEFAULT_DEVICE_ID=ESP32S3_Zone1
# URL service để script test gọi tới (mặc định http://localhost:<PORT>).
# TEST_SERVICE_URL=http://localhost:3001

# API key dùng chung cho /internal/* (đăng ký/hủy FCM token) VÀ /api/v1/notifications (đọc lịch sử).
# Màn hình kiosk gửi key này qua header x-api-key. Đặt chuỗi ngẫu nhiên đủ dài, cấp qua kênh riêng.
INTERNAL_API_KEY=change_me_to_a_random_secret

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
